{
  "name": "cel-compute-receipts",
  "version": "0.1.0",
  "description": "Compute receipts for pricing digital actions without identity or behavioral classification.",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdPriva/cel-compute-receipts.git"
  },
  "bugs": {
    "url": "https://github.com/adpriva/cel-compute-receipts/issues"
  },
  "homepage": "https://github.com/adpriva/cel-compute-receipts#readme",
  "files": [
    "src/",
    "examples/",
    "docs/",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ],
  "main": "src/cel.js",
  "exports": {
    ".": {
      "import": "./src/cel.js",
      "default": "./src/cel.js"
    },
    "./browser": {
      "import": "./src/cel-browser.js",
      "default": "./src/cel-browser.js"
    }
  },
  "bin": {
    "cel": "./src/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "bench": "node src/cli.js bench",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm test && npm run pack:check"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "proof-of-work",
    "client-puzzles",
    "anti-abuse",
    "rate-limiting",
    "ai-agents",
    "sequential-hashing",
    "compute-receipts"
  ],
  "author": "Cem Sel <cem@adpriva.com>",
  "license": "MIT"
}
